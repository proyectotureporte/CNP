    {
      "parameters": {
        "jsCode": "let text = $json.output;\n\n// 1. Limpiamos el mensaje que le llegará al WhatsApp del cliente\n// Quitamos la etiqueta [FINALIZADO] y todo lo que esté después de DATOS_REGISTRO\nlet mensajeWhatsApp = text.replace('[FINALIZADO]', '').split('DATOS_REGISTRO:')[0].trim();\n\n// 2. Extraemos la línea técnica para el Excel\nlet infoTecnica = text.split('DATOS_REGISTRO:')[1] || \"\";\n\n// 3. Picamos la información por los separadores \"|\"\nlet datosExtracted = {};\nif (infoTecnica) {\n    infoTecnica.split('|').forEach(item => {\n        let [clave, valor] = item.split(':');\n        if (clave && valor) {\n            datosExtracted[clave.trim().toLowerCase()] = valor.trim();\n        }\n    });\n}\n\nreturn {\n    texto_final_whatsapp: mensajeWhatsApp,\n    nombre: datosExtracted.nombre || \"No especificado\",\n    ciudad: datosExtracted.ciudad || \"No especificada\",\n    motivo: datosExtracted.motivo || \"No especificado\",\n    observacion: datosExtracted.cnp || \"Pendiente\"\n};"
      },
