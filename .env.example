# ============================================================================
# CNP | PERITUS — Plantilla de variables de entorno
# Copiar a .env.local y rellenar con valores reales. NUNCA commitear .env.local.
# ============================================================================

# --- PostgreSQL (almacén principal de datos) ---
DATABASE_URL=postgres://cnp_user:CONTRASENA@localhost:5432/cnp
# Opcional: tamaño máximo del pool de conexiones (def. 10)
# PG_POOL_MAX=10

# --- Servidor ---
# Puerto del servidor custom (server.js). Def. 3000
# PORT=3000

# --- Autenticación (JWT propio) ---
JWT_SECRET=

# --- Sanity (SOLO almacenamiento de archivos/assets) ---
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# --- Email (Resend) ---
RESEND_API_KEY=
EMAIL_FROM=CNP Portal <noresponder@cnp.com.co>
EMAIL_REPLY_TO=soporte@cnp.com.co

# --- App ---
NEXT_PUBLIC_APP_URL=https://cnp.com.co

# --- WhatsApp / Evolution API ---
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=Peritus
WHATSAPP_WEBHOOK_SECRET=
